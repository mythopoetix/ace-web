generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  image         String?
  googleId      String?      @unique
  fluentcrmId   Int?
  memberStatus  MemberStatus @default(PENDING)
  tier          Tier         @default(FREE)
  joinedAt      DateTime     @default(now())
  lastLoginAt   DateTime?

  videoProgress     VideoProgress[]
  discussions       Discussion[]
  comments          Comment[]
  feedbackItems     Feedback[]
  roadmapVotes      RoadmapVote[]
  eventRegistrations EventRegistration[]
  sessions          Session[]
  accounts          Account[]
  onboarding        OnboardingProgress?
  blueprint         BlueprintSubmission?

  @@index([email])
}

enum MemberStatus {
  PENDING
  VERIFIED
  ACTIVE
  CHURNED
  ADMIN
}

enum Tier {
  FREE
  PERSONAL
  PRO
  PRACTITIONER
  BETA
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Videos ──

model Video {
  id           String    @id @default(cuid())
  title        String
  description  String?
  embedUrl     String
  embedType    EmbedType @default(VIMEO)
  thumbnailUrl String?
  duration     Int?
  category     String
  tags         String[]
  sortOrder    Int       @default(0)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())

  progress VideoProgress[]
  eventId  String?
  event    Event?  @relation(fields: [eventId], references: [id])

  @@index([category])
}

enum EmbedType {
  VIMEO
  CLOUDFLARE
  YOUTUBE
}

model VideoProgress {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  watchedSeconds Int      @default(0)
  completed      Boolean  @default(false)
  lastWatchedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

// ── Events ──

model Event {
  id            String     @id @default(cuid())
  title         String
  description   String?
  type          EventType
  startTime     DateTime
  endTime       DateTime?
  location      String?
  capacity      Int?
  createdAt     DateTime   @default(now())

  registrations EventRegistration[]
  recordings    Video[]

  @@index([startTime])
}

enum EventType {
  LIVE_SESSION
  QA_CALL
  MASTERCLASS
  PRACTITIONER
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  status    String   @default("registered")
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

// ── Knowledge Base ──

model KBArticle {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  category   String
  excerpt    String?
  searchText String
  sortOrder  Int      @default(0)
  updatedAt  DateTime @default(now())

  @@index([category])
}

// ── Discussions ──

model Discussion {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  category  String
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]

  @@index([category, createdAt])
}

model Comment {
  id           String   @id @default(cuid())
  userId       String
  discussionId String
  parentId     String?
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  discussion Discussion @relation(fields: [discussionId], references: [id])
  parent     Comment?   @relation("Replies", fields: [parentId], references: [id])
  replies    Comment[]  @relation("Replies")

  @@index([discussionId, createdAt])
}

// ── Feedback ──

model Feedback {
  id          String         @id @default(cuid())
  userId      String
  type        FeedbackType
  title       String
  description String
  status      FeedbackStatus @default(OPEN)
  priority    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([type, status])
}

enum FeedbackType {
  BUG
  FEATURE
  QUESTION
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  SHIPPED
  CLOSED
  WONT_FIX
}

// ── Roadmap ──

model RoadmapItem {
  id          String        @id @default(cuid())
  title       String
  description String?
  category    String
  status      RoadmapStatus @default(PLANNED)
  eta         String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  votes RoadmapVote[]
}

enum RoadmapStatus {
  PLANNED
  IN_PROGRESS
  SHIPPED
  DEFERRED
}

model RoadmapVote {
  id            String      @id @default(cuid())
  userId        String
  roadmapItemId String
  createdAt     DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id])
  roadmapItem RoadmapItem @relation(fields: [roadmapItemId], references: [id])

  @@unique([userId, roadmapItemId])
}

// ── Telegram Feed ──

model TelegramMessage {
  id         String   @id @default(cuid())
  messageId  Int      @unique
  text       String?
  authorName String?
  mediaType  String?
  mediaUrl   String?
  createdAt  DateTime
  fetchedAt  DateTime @default(now())

  @@index([createdAt])
}

// ── Changelog ──

model ChangelogEntry {
  id          String   @id @default(cuid())
  commitSha   String   @unique
  message     String
  author      String?
  skills      String[]
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([publishedAt])
}

// ── Email Subscriptions ──

model EmailSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String
  fluentTag String?
  createdAt DateTime @default(now())
}

// ── Onboarding ──

model OnboardingProgress {
  id             String    @id @default(cuid())
  userId         String    @unique
  watchedIntro   Boolean   @default(false)
  blueprintDone  Boolean   @default(false)
  prepDone       Boolean   @default(false)
  sessionBooked  Boolean   @default(false)
  buildComplete  Boolean   @default(false)
  completedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlueprintSubmission {
  id            String   @id @default(cuid())
  userId        String   @unique
  fullName      String
  role          String
  domains       String
  values        String
  tools         String
  painPoints    String
  goals         String
  aiExperience  String
  schedule      String
  priorities    String
  submitted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
